# ─── ToolRent Environment Variables ──────────────────────────────────────────
# Copy this to .env and fill in your values before running docker-compose up

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=toolrent
DB_USERNAME=toolrent
DB_PASSWORD=change_me_in_production

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=toolrent-super-secret-key-minimum-32-chars-change-this
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:80,http://localhost:5173,https://*.toolrent.in
